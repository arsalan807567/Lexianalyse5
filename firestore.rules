rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'plan', 'usageCount', 'createdAt']) 
             && data.keys().size() == 5
             && data.uid == request.auth.uid
             && data.email is string
             && data.plan in ['free', 'pro']
             && data.usageCount is number
             && data.createdAt == request.time;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      // Only allow updating usageCount or plan if some condition is met. 
      // For a real app, this should be backend-only.
      // Here we simulate an update gate for usageCount.
      allow update: if isOwner(userId) 
                    && incoming().diff(existing()).affectedKeys().hasOnly(['usageCount', 'plan'])
                    && incoming().plan == existing().plan // Prevent self-upgrading in this demo
                    && incoming().usageCount >= existing().usageCount;
    }

    // --- Analysis Validation ---
    function isValidAnalysis(data) {
      return data.keys().hasAll(['userId', 'docName', 'docType', 'result', 'createdAt'])
             && data.keys().size() == 5
             && data.userId == request.auth.uid
             && data.docName is string && data.docName.size() <= 256
             && data.docType is string
             && data.result is map
             && data.createdAt == request.time;
    }

    match /users/{userId}/analyses/{analysisId} {
      allow list: if isOwner(userId);
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidAnalysis(incoming()) && isValidId(analysisId);
      allow delete: if isOwner(userId);
    }

    // --- Feedback Validation ---
    function isValidFeedback(data) {
      return data.keys().hasAll(['userId', 'userEmail', 'type', 'message', 'createdAt'])
             && (data.keys().size() == 5 || (data.keys().size() == 6 && data.keys().hasAll(['rating'])))
             && data.userId == request.auth.uid
             && data.userEmail is string
             && data.type in ['bug', 'feature', 'general']
             && data.message is string && data.message.size() <= 2000
             && (!data.keys().hasAll(['rating']) || (data.rating is number && data.rating >= 1 && data.rating <= 5))
             && data.createdAt == request.time;
    }

    match /feedback/{feedbackId} {
      allow list, get: if true;
      allow create: if isSignedIn() && isValidFeedback(incoming()) && isValidId(feedbackId);
    }
  }
}
